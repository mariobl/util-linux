#. type: Labeled list
#: ../disk-utils/sfdisk.8.adoc:122
#, no-wrap
msgid "*-T*, *--list-types*"
msgstr "*-T*, *--list-types*"

#. type: Plain text
#: ../disk-utils/sfdisk.8.adoc:124
msgid ""
"Print all supported types for the current disk label or the label specified "
