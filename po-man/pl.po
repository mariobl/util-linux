#. type: Labeled list
#: ../term-utils/agetty.8.adoc:177
#, no-wrap
msgid "*--nice* _number_"
msgstr "*--nice* _liczba_"

#. type: Plain text
#: ../term-utils/agetty.8.adoc:179
