"*uuid_clear*(3),\n"
"*uuid_compare*(3),\n"
"*uuid_copy*(3),\n"
"*uuid_generate*(3),\n"
"*uuid_is_null*(3),\n"
"*uuid_parse*(3),\n"
"*uuid_unparse*(3)\n"

