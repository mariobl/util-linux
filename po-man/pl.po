#: ../sys-utils/lscpu.1.adoc:97
msgid ""
"Display details about CPU caches. For details about available information "
"see *--help* output."
msgstr ""

#. type: Plain text
#: ../sys-utils/lscpu.1.adoc:99 ../sys-utils/lscpu.1.adoc:111
