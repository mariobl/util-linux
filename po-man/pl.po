msgstr "Wypisuje informacje o wszystkich trzech zasobach (domyślnie)."

#. type: Title ===
#: ../sys-utils/ipcs.1.adoc:50
#, no-wrap
msgid "Output formats"
msgstr "Formaty wyjściowe"

#. type: Plain text
#: ../sys-utils/ipcs.1.adoc:53
