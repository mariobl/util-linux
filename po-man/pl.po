#. type: Labeled list
#: ../disk-utils/sfdisk.8.adoc:119
#, no-wrap
msgid "*-s*, *--show-size* [__device__...]"
msgstr "*-s*, *--show-size* [__urządzenie__...]"

#. type: Plain text
#: ../disk-utils/sfdisk.8.adoc:121
#, fuzzy
#| msgid ""
