msgstr ""

#. type: Plain text
#: ../sys-utils/mountpoint.1.adoc:22
#, no-wrap
msgid "*mountpoint* checks whether the given _directory_ or _file_ is mentioned in the _/proc/self/mountinfo_ file.\n"
