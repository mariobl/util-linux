#: ../term-utils/agetty.8.adoc:243
#, no-wrap
msgid "b"
msgstr "b"

#. type: Plain text
#: ../term-utils/agetty.8.adoc:245
#, fuzzy
#| msgid "Sets the mode of the mountpoint."
msgid "Insert the baudrate of the current line."
msgstr "Ustawia tryb punktu montowania."

